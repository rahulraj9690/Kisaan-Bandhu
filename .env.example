# MongoDB Connection
MONGODB_URI=mongodb://127.0.0.1:27017/kisaanbandhu

# Or use MongoDB Atlas (for production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/kisaanbandhu

# Database URL for Prisma (if using PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/kisaanbandhu

# API Port (for local development)
PORT=5000

# Environment
NODE_ENV=development
